{
  "name": "school-oop/school-management-ddd",
  "description": "Proyecto simple School Management con DDD y Doctrine",
  "type": "project",
  "require": {
    "php": "^8.2",
    "doctrine/orm": "^2.20",
    "doctrine/dbal": "^3.8",
    "symfony/cache": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "School\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "School\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
